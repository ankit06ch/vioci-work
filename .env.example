# Vioci / schemagraph — copy to .env and fill in values

# --- VLM (parsing / chat) ---
# GOOGLE_API_KEY=...
# SCHEMAGRAPH_GOOGLE_USE_VERTEX=false

# --- Auth (production: set a long random secret) ---
# VIOCI_JWT_SECRET=change-me-in-production

# --- Local mode (default) ---
# No database vars → SQLite at workspace/.index.sqlite and files under workspace/

# --- Cloud mode (Supabase free tier) ---
# 1. Create a project at https://supabase.com
# 2. See docs/cloud-setup.md for bucket + connection string steps
# VIOCI_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# VIOCI_SUPABASE_URL=https://[PROJECT_REF].supabase.co
# VIOCI_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VIOCI_SUPABASE_BUCKET=vioci
# VIOCI_FILE_CACHE_DIR=~/.cache/vioci/projects
